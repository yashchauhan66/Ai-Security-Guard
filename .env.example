# ═══════════════════════════════════════════════════════════════════════════════
# CyberRakshak Guard — Production Environment Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# Quick start:
#   1. Copy to .env.production
#   2. Replace every placeholder value
#   3. Run: npx tsx scripts/validate-env.ts --file .env.production
#   4. Deploy: docker compose -f docker-compose.prod.yml up -d --build
#
# REQUIRED    = Must be set before any production deployment
# RECOMMENDED = Strongly recommended for full functionality
# CONDITIONAL = Required only when a specific provider/feature is enabled
# OPTIONAL    = Only needed for specific advanced features
#
# Generate secrets with:  openssl rand -base64 32
# ═══════════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 1: Core Database & Authentication  (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED: PostgreSQL connection string (not localhost).
# Docker Compose: postgresql://cyberrakshak:${POSTGRES_PASSWORD}@postgres:5432/cyberrakshak?schema=public
# External:      postgresql://user:password@host:5432/db?schema=public
DATABASE_URL="postgresql://cyberrakshak:CHANGE_ME_TO_REAL_PASSWORD@postgres:5432/cyberrakshak?schema=public"

# REQUIRED: NextAuth.js signing secret (min 32 chars).
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-at-least-32-random-characters"

# REQUIRED: Canonical public URL of the app (not localhost).
NEXTAUTH_URL="https://guard.yourdomain.com"

# RECOMMENDED: Set to "true" when behind a reverse proxy.
AUTH_TRUST_HOST="true"

# REQUIRED: Node environment. Must be "production".
NODE_ENV="production"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 2: Security Secrets & KMS  (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED: HMAC pepper for API key hashing (min 32 chars).
API_KEY_PEPPER="replace-with-at-least-32-random-characters"

# REQUIRED: Peppers for SCIM token hashing (min 32 chars each).
SCIM_TOKEN_PEPPER="replace-with-at-least-32-random-characters"
WEBHOOK_SECRET_PEPPER="replace-with-at-least-32-random-characters"

# REQUIRED: Report signing secret (min 32 chars).
REPORT_SIGNING_SECRET="replace-with-at-least-32-random-characters"

# REQUIRED: Audit export signing secret. Falls back to API_KEY_PEPPER if not set.
AUDIT_EXPORT_SECRET=""

# REQUIRED: Secret store provider for encrypted webhook signing secrets.
# Allowed: aws-kms, gcp-kms, vault  (local is rejected in production)
SECRET_STORE_PROVIDER="aws-kms"

# CONDITIONAL: Required when SECRET_STORE_PROVIDER=aws-kms
AWS_KMS_KEY_ID=""
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# CONDITIONAL: Required when SECRET_STORE_PROVIDER=gcp-kms
GCP_PROJECT_ID=""
GCP_LOCATION="global"
GCP_KEY_RING=""
GCP_CRYPTO_KEY=""

# CONDITIONAL: Required when SECRET_STORE_PROVIDER=vault
VAULT_ADDR=""
VAULT_TOKEN=""
VAULT_TRANSIT_KEY="cyberrakshak-webhooks"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 3: Redis & Distributed State  (RECOMMENDED)
# ═══════════════════════════════════════════════════════════════════════════════

# Required for multi-instance deployments. Falls back to in-memory with warning.
# Either configure Upstash REST (preferred) or a standard Redis URL.

# OPTION A (preferred): Upstash Redis REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# OPTION B: Standard Redis URL (for self-hosted Redis)
REDIS_URL=""


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 4: Email Delivery (SMTP / Resend / AWS SES)  (RECOMMENDED)
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED: Email provider. Allowed: mock, resend, aws-ses, smtp
EMAIL_PROVIDER="resend"

# REQUIRED: Sender email address (must use real domain, not example.com).
EMAIL_FROM="CyberRakshak Guard <security@yourdomain.com>"

# CONDITIONAL: Required when EMAIL_PROVIDER=resend
RESEND_API_KEY=""

# CONDITIONAL: Required when EMAIL_PROVIDER=aws-ses
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"

# CONDITIONAL: Required when EMAIL_PROVIDER=smtp
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_TLS="true"
SMTP_HELO=""


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 5: Billing (Razorpay)  (RECOMMENDED)
# ═══════════════════════════════════════════════════════════════════════════════

# When unset, /api/billing/checkout returns mock orders for development.

# REQUIRED (for billing): Razorpay live-mode credentials.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# OPTIONAL: Map Razorpay plan IDs to internal plans.
RAZORPAY_PLAN_STARTER=""
RAZORPAY_PLAN_PRO=""
RAZORPAY_PLAN_AGENCY=""

# OPTIONAL: Enterprise contact email for billing CTAs.
ENTERPRISE_CONTACT_EMAIL="sales@yourdomain.com"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 6: Vector Store & RAG  (CONDITIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED: Vector store provider. Allowed: qdrant, pgvector
VECTOR_PROVIDER="qdrant"

# CONDITIONAL: Required when VECTOR_PROVIDER=qdrant
QDRANT_URL="http://qdrant:6333"
QDRANT_API_KEY=""

# CONDITIONAL: Required when VECTOR_PROVIDER=pgvector
PGVECTOR_DATABASE_URL=""

# Embedding API (required for semantic detectors)
EMBEDDING_API_URL=""
EMBEDDING_API_KEY=""

# Vector dimensions (must match the embedding model)
VECTOR_DIMENSIONS="64"

# RAG limits
RAG_MAX_FILE_BYTES="10485760"
RAG_MAX_PAGES="50"
OCR_TIMEOUT_MS="30000"
OCR_LANGUAGES="eng+hin"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 7: Background Workers  (RECOMMENDED)
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED: Auth token for webhook worker cron endpoint (min 32 chars).
WEBHOOK_WORKER_TOKEN="replace-with-at-least-32-random-characters"
WEBHOOK_WORKER_INTERVAL_MS="5000"
WEBHOOK_WORKER_HEALTH_PORT="3099"

# Report worker
REPORT_WORKER_TOKEN="replace-with-at-least-32-random-characters"

# SIEM worker
SIEM_WORKER_INTERVAL_MS="5000"
SIEM_WORKER_HEALTH_PORT="3098"

# Threat intelligence worker
THREAT_INTEL_WORKER_INTERVAL_MS="300000"
THREAT_INTEL_WORKER_HEALTH_PORT="3097"

# Background worker interval for scheduled reports and RAG scans
BACKGROUND_WORKER_INTERVAL_MS="30000"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 8: ML Detectors & Feature Flags  (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# Classifiers are additive. Rule-based guards always remain active.
ENABLE_SEMANTIC_DETECTORS="false"
ENABLE_MULTILINGUAL_DETECTORS="false"
ENABLE_HINDI_HINGLISH_DETECTION="false"
ENABLE_PHASE11_MULTILINGUAL_DETECTORS="false"

DETECTOR_VERSION="phase5-rule-v1"
PERSIST_CLASSIFIER_EVAL="false"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 9: Observability & SIEM  (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_EXPORTER_OTLP_HEADERS=""


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 10: Plan Limits & Rate Limiting  (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

FREE_PLAN_LIMIT_PER_MONTH="100"
STARTER_LIMIT_PER_MONTH="10000"
PRO_LIMIT_PER_MONTH="50000"
AGENCY_LIMIT_PER_MONTH="250000"
ENTERPRISE_LIMIT_PER_MONTH="5000000"

MAX_GUARD_TEXT_LENGTH="8000"
DEFAULT_RPM="60"
PUBLIC_ANALYZE_RPM="20"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 11: Docker Compose & Deployment  (CONDITIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED (for Docker Compose): PostgreSQL root password (min 16 chars).
POSTGRES_PASSWORD="replace-with-a-long-random-password-at-least-16-chars"

APP_ENV_FILE=".env.production"
BACKUP_DIR="./backups"
BASE_URL="https://guard.yourdomain.com"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 12: Demo / Development  (DEVELOPMENT ONLY)
# ═══════════════════════════════════════════════════════════════════════════════

# Remove or comment out these in production.
DEMO_USER_EMAIL="demo@cyberrakshak.dev"
DEMO_USER_PASSWORD="demo-cyberrakshak-2026"
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 13: Agent Firewall / Computer-Use Guard  (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

CYBERSECURITYGUARD_API_KEY=""
CYBERSECURITYGUARD_BASE_URL="http://localhost:3000"
CYBERSECURITYGUARD_AGENT_FIREWALL_ENABLED="true"
CYBERSECURITYGUARD_FAIL_CLOSED="true"
CYBERSECURITYGUARD_ALLOWED_WORKSPACE_DIR=""
CYBERSECURITYGUARD_BLOCK_DOTENV_READ="true"
CYBERSECURITYGUARD_REQUIRE_APPROVAL_FOR_EMAIL_SEND="true"
CYBERSECURITYGUARD_REQUIRE_APPROVAL_FOR_FILE_WRITE="true"
CYBERSECURITYGUARD_REQUIRE_APPROVAL_FOR_EXTERNAL_POST="true"
CYBERSECURITYGUARD_BLOCK_TERMINAL_DANGEROUS_COMMANDS="true"

# Backward-compatible short aliases.
CYBERGUARD_API_KEY=""
CYBERGUARD_BASE_URL=""
CYBERGUARD_AGENT_FIREWALL_ENABLED="true"

AGENT_FIREWALL_DEFAULT_ACTION="DENY"
AGENT_FIREWALL_APPROVAL_THRESHOLD="70"
AGENT_FIREWALL_BLOCK_THRESHOLD="90"

# Advanced AI Security modules (MVP 1: Context Lineage + Blast Radius).
CYBERSECURITYGUARD_LINEAGE_ENABLED="true"
CYBERSECURITYGUARD_BLAST_RADIUS_ENABLED="true"
# Reserved for later MVPs (off until implemented).
CYBERSECURITYGUARD_MCP_DRIFT_ENABLED="true"
CYBERSECURITYGUARD_LEGAL_BOUNDARY_ENABLED="true"
CYBERSECURITYGUARD_MEMORY_FIREWALL_ENABLED="true"
# Backward-compatible short aliases.
CYBERGUARD_LINEAGE_ENABLED="true"
CYBERGUARD_BLAST_RADIUS_ENABLED="true"
CYBERGUARD_MCP_DRIFT_ENABLED="true"
CYBERGUARD_LEGAL_BOUNDARY_ENABLED="true"
CYBERGUARD_MEMORY_FIREWALL_ENABLED="true"


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 14: Enterprise Identity (SAML / SCIM)  (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

SAML_SP_ENTITY_ID=""
SAML_SP_ACS_URL=""
SAML_SP_PRIVATE_KEY=""
SAML_SP_CERTIFICATE=""
