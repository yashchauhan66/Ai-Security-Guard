{
  "name": "@soterai/extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc && vite build && vite build --config vite.content.config.ts && vite build --config vite.lineage.config.ts",
    "package": "npm run build && node scripts/package.js",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@soterai/detectors": "file:../../packages/detectors",
    "@soterai/policy-engine": "file:../../packages/policy-engine",
    "@soterai/shared": "file:../../packages/shared"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "typescript": "^5.5.4",
    "vite": "^8.1.3",
    "vite-plugin-static-copy": "^4.1.1"
  }
}
