{
  "manifest_version": 3,
  "name": "Soter Enterprise AI Control Plane",
  "short_name": "Soter",
  "description": "Stops secrets, PII, source code, and sensitive business data from leaking into AI tools like ChatGPT, Claude, and Gemini.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "contextMenus",
    "sidePanel",
    "storage",
    "scripting",
    "alarms"
  ],
  "optional_permissions": [
    "identity",
    "identity.email"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://bard.google.com/*",
    "*://perplexity.ai/*",
    "*://poe.com/*",
    "*://openrouter.ai/*",
    "*://replit.com/*",
    "*://*.replit.dev/*",
    "*://stackblitz.com/*",
    "*://*.stackblitz.io/*",
    "*://codesandbox.io/*",
    "*://*.csb.app/*",
    "*://github.dev/*",
    "*://*.github.dev/*",
    "*://bolt.new/*",
    "*://v0.dev/*",
    "*://lovable.dev/*",
    "*://openwebui.com/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://bard.google.com/*",
        "*://perplexity.ai/*",
        "*://poe.com/*",
        "*://openrouter.ai/*",
        "*://replit.com/*",
        "*://*.replit.dev/*",
        "*://stackblitz.com/*",
        "*://*.stackblitz.io/*",
        "*://codesandbox.io/*",
        "*://*.csb.app/*",
        "*://github.dev/*",
        "*://*.github.dev/*",
        "*://bolt.new/*",
        "*://v0.dev/*",
        "*://lovable.dev/*",
        "*://openwebui.com/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/source-lineage-entry.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Soter Enterprise AI Control Plane",
    "default_popup": "popup/index.html",
    "default_icon": { 
      "16": "assets/icon-16.png", 
      "32": "assets/icon-32.png", 
      "48": "assets/icon-48.png", 
      "128": "assets/icon-128.png" 
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "icons": { 
    "16": "assets/icon-16.png", 
    "32": "assets/icon-32.png", 
    "48": "assets/icon-48.png", 
    "128": "assets/icon-128.png",
    "192": "assets/icon-192.png",
    "512": "assets/icon-512.png"
  },
  "storage": {
    "managed_schema": "managed-schema.json"
  }
}
