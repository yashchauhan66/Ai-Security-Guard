{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "../..",
    "outDir": "dist",
    "lib": ["ES2020", "DOM"]
  },
  "include": [
    "src",
    "../../packages/detectors/src",
    "../../packages/policy-engine/src",
    "../../packages/shared/src"
  ],
  "exclude": ["dist"]
}
