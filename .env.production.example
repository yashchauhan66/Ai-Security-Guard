# Database
DATABASE_URL="postgresql://user:password@host:5432/soter?schema=public"
REDIS_URL="redis://:password@host:6379/0"

# Auth
NEXTAUTH_URL="https://your-soter-domain.com"
NEXTAUTH_SECRET="generate-a-strong-secret-key-here"

# Core Configuration
NEXT_PUBLIC_APP_URL="https://your-soter-domain.com"
ENROLLMENT_SECRET_KEY="generate-enrollment-secret-here"
ADMIN_EMAIL="admin@your-company.com"

