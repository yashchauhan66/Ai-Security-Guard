{
  "name": "SoterAI PII Redactor",
  "method": "POST",
  "url": "{soter_base_url}/api/guard/input",
  "headers": {
    "Content-Type": "application/json",
    "x-api-key": "{soter_api_key}",
    "User-Agent": "soterai-voiceflow/1.0"
  },
  "body": {
    "message": "{last_user_message}",
    "metadata": {
      "projectId": "{project_id}",
      "source": "voiceflow",
      "mode": "redact"
    }
  },
  "saveResponse": {
    "soter_safe_text": "safeText",
    "soter_risk_score": "riskScore",
    "soter_risk_types": "riskTypes"
  }
}
