{
  "name": "SoterAI Output Guard",
  "method": "POST",
  "url": "{soter_base_url}/api/guard/output",
  "headers": {
    "Content-Type": "application/json",
    "x-api-key": "{soter_api_key}",
    "User-Agent": "soterai-voiceflow/1.0"
  },
  "body": {
    "aiResponse": "{assistant_output}",
    "metadata": {
      "projectId": "{project_id}",
      "source": "voiceflow"
    }
  },
  "saveResponse": {
    "soter_allowed": "allowed",
    "soter_risk_score": "riskScore",
    "soter_risk_types": "riskTypes",
    "soter_safe_text": "safeText",
    "soter_reason": "reason"
  }
}
